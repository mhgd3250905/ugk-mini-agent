# Copy this file to .env before using docker-compose.prod.yml.

ZHIPU_GLM_API_KEY=replace-me
DEEPSEEK_API_KEY=replace-me
XIAOMI_MIMO_API_KEY=replace-me
ALI_CODEPLAN_API_KEY=replace-me
# Optional local-only bootstrap. Keep false in normal Docker/production runs;
# API txt files are temporary developer notes, not formal config sources.
UGK_ALLOW_LOCAL_API_TXT_BOOTSTRAP=false
HOST=0.0.0.0
PORT=3000
HOST_PORT=3000
WEB_ACCESS_BROWSER_GUI_PORT=3901
WEB_ACCESS_BROWSER_PROFILE_DIR=/config/chrome-profile-sidecar
WEB_ACCESS_BROWSER_PUBLIC_BASE_URL=http://ugk-pi:3000
WEB_ACCESS_BROWSER_UPLOAD_APP_DIR=/app/.data/browser-upload
WEB_ACCESS_BROWSER_UPLOAD_BROWSER_DIR=/config/upload
# Optional browser registry. Leave empty to synthesize the current default Chrome sidecar.
# browserId is user-defined; each configured Chrome instance must use its own profile/config dir.
UGK_DEFAULT_BROWSER_ID=default
UGK_BROWSER_INSTANCES_JSON=[{"browserId":"default","name":"Default","cdpHost":"172.31.250.10","cdpPort":9223,"guiUrl":"https://127.0.0.1:3901/","profileLabel":"chrome-sidecar"},{"browserId":"chrome-01","name":"chrome-01","cdpHost":"172.31.250.11","cdpPort":9223,"guiUrl":"https://127.0.0.1:3902/","profileLabel":"chrome-sidecar-chrome-01"},{"browserId":"chrome-02","name":"chrome-02","cdpHost":"172.31.250.12","cdpPort":9223,"guiUrl":"https://127.0.0.1:3903/","profileLabel":"chrome-sidecar-chrome-02"}]
UGK_BROWSER_SCOPE_ROUTE_CACHE_PATH=/app/.data/browser-scope-routes.json
UGK_BROWSER_MEM_LIMIT=2g
UGK_BROWSER_MEM_RESERVATION=512m
CONN_WORKER_MAX_CONCURRENCY=3
# Team Runtime: set to "true" to enable /v1/team/* routes and team-worker.
TEAM_RUNTIME_ENABLED=true
# Team data directory (default: .data/team)
TEAM_DATA_DIR=/app/.data/team
# Comma-separated role IDs to run with real LLM. Unset = all mock.
# Roles: discovery, evidence_collector, classifier, reviewer
TEAM_REAL_ROLES=discovery,evidence_collector,classifier,reviewer
# Worker poll interval in ms (default: 3000)
TEAM_WORKER_POLL_INTERVAL_MS=3000
# Max concurrent team runs (default: 1)
TEAM_MAX_CONCURRENT_RUNS=1
# Worker phase timeout in ms (default: 900000 = 15 min)
TEAM_WORKER_PHASE_TIMEOUT_MS=900000
# Max run duration in minutes (default: 100). Per-run override via API.
TEAM_MAX_RUN_DURATION_MINUTES=100
# Per-role-task timeout in ms (default: 180000 = 3 min)
TEAM_ROLE_TASK_TIMEOUT_MS=180000
# Max retries per failed role task (default: 1)
TEAM_ROLE_TASK_MAX_RETRIES=1
SEARXNG_BASE_URL=http://ugk-pi-searxng:8080
SEARXNG_HOST_PORT=48080
# Generate a random production secret, for example: openssl rand -hex 32
SEARXNG_SECRET=replace-me-with-random-secret
UGK_SEARXNG_MEM_LIMIT=512m
UGK_SEARXNG_MEM_RESERVATION=128m
PUBLIC_BASE_URL=https://your-public-host.example.com
# Feishu app credentials can be set in Web -> 飞书设置 after first boot.
# These env values are bootstrap fallbacks for fresh deployments.
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_API_BASE=https://open.feishu.cn/open-apis
FEISHU_ENABLED=false
FEISHU_SUBSCRIPTION_MODE=ws
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=
FEISHU_AGENT_BASE_URL=http://127.0.0.1:3000
# These are fallback values. Web -> 飞书设置 persists runtime values in .data/agent/feishu/settings.json.
FEISHU_ALLOWED_CHAT_IDS=
FEISHU_ACTIVITY_CHAT_IDS=
FEISHU_ACTIVITY_OPEN_IDS=
UGK_APP_ENV_FILE=.env
UGK_APP_LOG_DIR=./logs/app
UGK_AGENT_DATA_DIR=./.data/agent
UGK_AGENTS_DATA_DIR=./.data/agents
UGK_MODEL_SETTINGS_PATH=/app/.data/agent/model-settings.json
UGK_NGINX_LOG_DIR=./logs/nginx
UGK_BROWSER_CONFIG_DIR=./.data/chrome-sidecar
UGK_BROWSER_UPLOAD_DIR=./.data/chrome-sidecar/upload
UGK_BROWSER_CHROME_01_CONFIG_DIR=./.data/chrome-sidecar-chrome-01
UGK_BROWSER_CHROME_01_UPLOAD_DIR=./.data/chrome-sidecar-chrome-01/upload
WEB_ACCESS_BROWSER_CHROME_01_GUI_PORT=3902
WEB_ACCESS_BROWSER_CHROME_01_PROFILE_DIR=/config/chrome-profile-sidecar
UGK_BROWSER_CHROME_01_MEM_LIMIT=2g
UGK_BROWSER_CHROME_01_MEM_RESERVATION=512m
UGK_BROWSER_CHROME_02_CONFIG_DIR=./.data/chrome-sidecar-chrome-02
UGK_BROWSER_CHROME_02_UPLOAD_DIR=./.data/chrome-sidecar-chrome-02/upload
WEB_ACCESS_BROWSER_CHROME_02_GUI_PORT=3903
WEB_ACCESS_BROWSER_CHROME_02_PROFILE_DIR=/config/chrome-profile-sidecar
UGK_BROWSER_CHROME_02_MEM_LIMIT=2g
UGK_BROWSER_CHROME_02_MEM_RESERVATION=512m
UGK_SEARXNG_CONFIG_DIR=./deploy/searxng
UGK_SEARXNG_CACHE_DIR=./.data/searxng
# Production should point this at shared storage, not the clean Git worktree.
# Tencent example: /home/ubuntu/ugk-claw-shared/runtime/skills-user
# Aliyun example: /root/ugk-claw-shared/runtime/skills-user
UGK_RUNTIME_SKILLS_USER_DIR=./runtime/skills-user
# Shared Python venv / runtime dependency cache used by Chat, Conn worker, and Team worker.
# Production should point this at shared storage so rebuilds do not erase installed Python packages.
UGK_RUNTIME_DEPS_HOST_DIR=./.data/runtime-deps
# Optional explicit venv path for non-compose runs; compose sets the Docker path to python-venv-linux.
UGK_RUNTIME_PYTHON_VENV_DIR=

# Optional Docker build mirror host for Debian apt sources.
# Example for Aliyun ECS: mirrors.aliyun.com
APT_MIRROR_HOST=

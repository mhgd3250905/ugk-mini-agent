# UGK Mini Agent
# Copy to .env.native or set the variables in your shell before npm run native:start.

HOST=127.0.0.1
PORT=8888
PUBLIC_BASE_URL=http://127.0.0.1:8888

# Optional runtime locations. Defaults are relative to the project root:
# UGK_DATA_DIR=.data
# UGK_LOG_DIR=logs/native
# UGK_TOOLS_DIR=.data/tools
#
# For LAN or reverse-proxy access, set HOST=0.0.0.0 and PUBLIC_BASE_URL to the external URL.

TEAM_RUNTIME_ENABLED=true

# Add model providers and API keys from the API Source page after startup.

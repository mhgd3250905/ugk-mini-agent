{
  "name": "ugk-pi",
  "version": "1.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "worker:conn": "tsx src/workers/conn-worker.ts",
    "worker:feishu": "tsx src/workers/feishu-worker.ts",
    "test": "node --test --test-concurrency=1 --import tsx test/**/*.test.ts",
    "design:lint": "node ./node_modules/@google/design.md/dist/index.js lint DESIGN.md",
    "docker:build": "docker build -t ugk-pi:local .",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "docker:up:prod": "docker compose -f docker-compose.prod.yml up --build -d",
    "docker:down:prod": "docker compose -f docker-compose.prod.yml down",
    "docker:logs:prod": "docker compose -f docker-compose.prod.yml logs -f",
    "docker:logs:nginx": "docker compose -f docker-compose.prod.yml logs -f nginx",
    "docker:status:prod": "docker compose -f docker-compose.prod.yml ps",
    "docker:health:prod": "node scripts/docker-health.mjs",
    "docker:doctor": "node scripts/local-port-doctor.mjs",
    "docker:chrome:start": "node scripts/sidecar-chrome.mjs start",
    "docker:chrome:restart": "node scripts/sidecar-chrome.mjs restart",
    "docker:chrome:check": "node scripts/sidecar-chrome.mjs check",
    "docker:chrome:status": "node scripts/sidecar-chrome.mjs status",
    "docker:chrome:open": "node scripts/sidecar-chrome.mjs open",
    "server:ops": "node scripts/server-ops.mjs",
    "worker:team": "tsx src/workers/team-worker.ts",
    "test:team": "node --test --test-concurrency=1 --import tsx test/team-*.test.ts",
    "team:browser-smoke": "node scripts/team-browser-binding-smoke.mjs"
  },
  "dependencies": {
    "@fastify/multipart": "^10.0.0",
    "@larksuiteoapi/node-sdk": "^1.62.0",
    "@mariozechner/pi-coding-agent": "^0.70.6",
    "@sinclair/typebox": "^0.34.41",
    "fastify": "^5.6.1",
    "flatpickr": "^4.6.13",
    "marked": "^18.0.2",
    "nodemailer": "^6.9.16"
  },
  "devDependencies": {
    "@google/design.md": "^0.1.1",
    "@types/node": "^24.6.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}

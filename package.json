{
  "name": "ugk-mini-agent",
  "version": "1.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "worker:conn": "tsx src/workers/conn-worker.ts",
    "test": "node --test --test-concurrency=1 --import tsx test/**/*.test.ts",
    "design:lint": "node ./node_modules/@google/design.md/dist/index.js lint DESIGN.md",
    "runtime:check": "node scripts/runtime-deps.mjs check",
    "native:doctor": "node scripts/native-doctor.mjs",
    "native:start": "node scripts/native-supervisor.mjs",
    "worker:team": "tsx src/workers/team-worker.ts",
    "test:team": "node --test --test-concurrency=1 --import tsx test/team-*.test.ts",
    "team:task-factory": "tsx src/team/task-factory-cli.ts",
    "team-console:build": "npm --prefix apps/team-console run build",
    "team-console:test": "npm --prefix apps/team-console run test",
    "code:size": "node scripts/code-size-baseline.mjs"
  },
  "dependencies": {
    "@cfworker/json-schema": "^4.1.1",
    "@fastify/multipart": "^10.0.0",
    "@mariozechner/pi-coding-agent": "^0.70.6",
    "@modelcontextprotocol/client": "^2.0.0-alpha.2",
    "@sinclair/typebox": "^0.34.41",
    "fastify": "^5.6.1",
    "flatpickr": "^4.6.13",
    "marked": "^18.0.2",
    "nodemailer": "^6.9.16"
  },
  "devDependencies": {
    "@google/design.md": "^0.1.1",
    "@types/node": "^24.6.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
